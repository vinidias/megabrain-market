---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { coverWebpSources } from '../lib/cover-webp';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Committed covers have generated .webp / -640.webp siblings (guarded by
// tests/blog-cover-webp.test.mjs); coverWebpSources() returns null when the
// siblings don't exist (e.g. deploy-generated /blog/og/*.png covers). Cards
// render at ~340-540px, so the 640w thumb covers 1x displays and the full
// WebP covers high-DPI ones.

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "MegaBrain Market Blog",
  "description": "Analysis, guides, and deep dives on real-time intelligence, OSINT, geopolitics, markets, and the open-source tools behind MegaBrain Market.",
  "url": "https://www.megabrain.market/blog/",
  "inLanguage": "en-US",
  "publisher": {
    "@type": "Organization",
    "name": "MegaBrain Market",
    "url": "https://www.megabrain.market",
    "logo": {
      "@type": "ImageObject",
      "url": "https://www.megabrain.market/favico/apple-touch-icon.png"
    }
  },
  "blogPost": posts.map(post => ({
    "@type": "BlogPosting",
    "headline": post.data.title,
    "description": post.data.description,
    "datePublished": post.data.pubDate.toISOString(),
    ...(post.data.modifiedDate ? { "dateModified": post.data.modifiedDate.toISOString() } : {}),
    "url": `https://www.megabrain.market/blog/posts/${post.id}/`,
    "image": post.data.heroImage ? `https://www.megabrain.market${post.data.heroImage}` : "https://www.megabrain.market/favico/og-image.png"
  }))
};
---

<Base
  title="MegaBrain Market Blog"
  description="Insights on real-time global intelligence, OSINT, geopolitics, markets, and the open-source tools that power situational awareness."
  metaTitle="MegaBrain Market Blog | Real-Time Intelligence, OSINT, Geopolitics & Markets"
  jsonLd={jsonLd}
>
  <div class="blog-hero">
    <div class="badge">
      <span class="dot"></span>
      Intelligence Feed
    </div>
    <h1>Noise<span class="green">.</span>Signal<span class="green">.</span>Blog</h1>
    <p class="subtitle">
      Analysis, guides, and deep dives on real-time intelligence, OSINT, geopolitics, markets, and the open-source tools behind MegaBrain Market.
    </p>
  </div>
  <div class="blog-list">
    <div class="post-grid">
      {posts.map((post) => {
        const cover = coverWebpSources(post.data.heroImage);
        return (
        <a href={`/blog/posts/${post.id}/`} class="post-card">
          {post.data.heroImage && (
            <picture>
              {cover && (
                <source
                  type="image/webp"
                  srcset={`${cover.webp640} 640w, ${cover.webp} 1200w`}
                  sizes="(max-width: 740px) calc(100vw - 3rem), 350px"
                />
              )}
              <img
                src={post.data.heroImage}
                alt={post.data.title}
                class="post-card-img"
                loading="lazy"
                width="600"
                height="315"
              />
            </picture>
          )}
          <div class="tag">{post.data.audience}</div>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
          <div class="meta">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </time>
          </div>
        </a>
        );
      })}
    </div>
  </div>
</Base>
